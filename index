}
.nav.scrolled{height:60px;top:8px;border-color:rgba(247,148,29,.25);background:rgba(8,8,9,.88)}
.brand{display:flex;align-items:center;gap:12px}.brand-badge{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,var(--gold),#ffe0a5);color:#0a0a0a;display:grid;place-items:center;font-weight:900;letter-spacing:-1px}.brand-text strong{display:block;font-family:"Space Grotesk",sans-serif;font-size:20px;letter-spacing:2px}.brand-text strong span{color:var(--gold)}.brand-text small{display:block;color:var(--soft);font-size:9px;letter-spacing:1.7px;text-transform:uppercase;margin-top:2px}
.nav-links{display:flex;align-items:center;gap:24px;list-style:none}.nav-links a{font-size:12px;text-transform:uppercase;letter-spacing:1.3px;color:rgba(255,255,255,.66);font-weight:700}.nav-links a:hover{color:#fff}.nav-quote{padding:12px 18px;border-radius:16px;background:var(--gold);color:#060606!important;box-shadow:0 12px 28px rgba(247,148,29,.28)}
.menu-btn{display:none;width:44px;height:44px;border:1px solid var(--line);border-radius:14px;background:rgba(255,255,255,.05);color:#fff;font-size:21px}.mobile-panel{position:fixed;top:86px;left:16px;right:16px;display:none;z-index:999;padding:18px;border:1px solid rgba(247,148,29,.24);border-radius:22px;background:rgba(10,10,10,.96);backdrop-filter:blur(22px)}.mobile-panel.open{display:block}.mobile-panel a{display:block;padding:15px 8px;border-bottom:1px solid rgba(255,255,255,.08);font-weight:800;text-transform:uppercase;letter-spacing:1px}.mobile-panel a:last-child{border-bottom:0;color:var(--gold)}

/* HERO */
.hero{min-height:100vh;display:grid;align-items:center;position:relative;padding:140px 0 80px;overflow:hidden}.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center}.eyebrow{display:inline-flex;align-items:center;gap:10px;padding:9px 13px;border:1px solid rgba(247,148,29,.24);border-radius:999px;background:rgba(247,148,29,.08);color:var(--gold2);font-size:11px;letter-spacing:1.8px;text-transform:uppercase;font-weight:800}.eyebrow:before{content:"";width:7px;height:7px;border-radius:50%;background:var(--gold);box-shadow:0 0 18px var(--gold)}
h1{font-family:"Space Grotesk",Inter,sans-serif;font-size:clamp(48px,7.4vw,96px);line-height:.91;letter-spacing:-4px;margin:24px 0 22px}.gradient-word{display:inline-block;background:linear-gradient(90deg,#fff 0%,#ffd193 44%,var(--gold) 100%);-webkit-background-clip:text;background-clip:text;color:transparent}.hero p{color:var(--muted);font-size:18px;line-height:1.76;max-width:620px}.hero-actions{display:flex;gap:14px;margin-top:34px;flex-wrap:wrap}.btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;border-radius:18px;padding:16px 22px;font-size:13px;font-weight:900;letter-spacing:1.2px;text-transform:uppercase;transition:.25s ease}.btn-primary{background:var(--gold);color:#070707;box-shadow:0 22px 46px rgba(247,148,29,.26)}.btn-primary:hover{transform:translateY(-3px);background:var(--gold2)}.btn-secondary{border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:#fff}.btn-secondary:hover{border-color:var(--line2);transform:translateY(-3px)}
.hero-card{position:relative;min-height:560px;border:1px solid rgba(255,255,255,.12);border-radius:36px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.025));box-shadow:var(--shadow);overflow:hidden;padding:28px}.hero-card:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 70% 18%,rgba(247,148,29,.24),transparent 38%),linear-gradient(135deg,rgba(247,148,29,.08),transparent 42%);}.mesh{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.07) 1px,transparent 1px);background-size:42px 42px;mask-image:linear-gradient(to bottom,black,transparent 88%);opacity:.55}.big-mark{position:absolute;right:-22px;bottom:28px;font-family:"Space Grotesk";font-size:116px;font-weight:900;letter-spacing:-8px;color:rgba(255,255,255,.045);writing-mode:vertical-rl}.floating-panel{position:absolute;left:28px;right:28px;bottom:28px;border:1px solid rgba(255,255,255,.14);border-radius:28px;padding:22px;background:rgba(4,4,5,.72);backdrop-filter:blur(18px)}.panel-title{font-size:12px;text-transform:uppercase;letter-spacing:1.8px;color:var(--gold);font-weight:900;margin-bottom:14px}.mini-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.mini-stat{padding:16px;border-radius:18px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08)}.mini-stat strong{display:block;font-size:28px;font-family:"Space Grotesk";color:#fff}.mini-stat span{display:block;margin-top:4px;font-size:10px;line-height:1.35;color:var(--soft);text-transform:uppercase;letter-spacing:1px}.seal{position:absolute;top:32px;left:32px;width:142px;height:142px;border-radius:50%;border:1px solid rgba(247,148,29,.32);display:grid;place-items:center;background:rgba(247,148,29,.06);box-shadow:inset 0 0 45px rgba(247,148,29,.08)}.seal span{text-align:center;font-family:"Space Grotesk";font-size:18px;font-weight:900;line-height:1.05;color:var(--gold2)}

/* STRIP */
.strip{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.035);overflow:hidden}.marquee{display:flex;width:max-content;animation:marq 26s linear infinite}.marquee span{padding:18px 28px;color:rgba(255,255,255,.7);font-size:12px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase}.marquee b{color:var(--gold);margin-left:22px}@keyframes marq{to{transform:translateX(-50%)}}

/* SECTION COMMON */
.section{padding:112px 0}.section-head{display:flex;align-items:end;justify-content:space-between;gap:38px;margin-bottom:42px}.section h2{font-family:"Space Grotesk";font-size:clamp(36px,5vw,64px);line-height:.95;letter-spacing:-2.2px}.section-head p{max-width:470px;color:var(--muted);line-height:1.75}.muted{color:var(--muted)}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px}.about-copy{border:1px solid var(--line);border-radius:var(--radius);padding:38px;background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.025))}.about-copy p{color:var(--muted);line-height:1.85;margin-top:16px}.quote{margin-top:26px;padding:18px 22px;border-left:3px solid var(--gold);border-radius:0 20px 20px 0;background:rgba(247,148,29,.08);font-weight:900;color:#fff}.feature-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.feature{padding:24px;border:1px solid var(--line);border-radius:24px;background:var(--card);transition:.25s}.feature:hover{transform:translateY(-5px);border-color:var(--line2);background:linear-gradient(180deg,rgba(247,148,29,.10),rgba(255,255,255,.035))}.icon{width:46px;height:46px;border-radius:16px;background:rgba(247,148,29,.12);border:1px solid rgba(247,148,29,.22);display:grid;place-items:center;margin-bottom:16px}.feature h3,.service h3,.why-card h3,.step h3{font-family:"Space Grotesk";font-size:20px;letter-spacing:-.5px}.feature p,.service p,.why-card p,.step p{margin-top:9px;color:var(--muted);font-size:14px;line-height:1.65}

/* SERVICES */
.services{background:linear-gradient(180deg,#f5efe4,#fff7eb);color:#090909;position:relative;overflow:hidden}.services:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 96% 8%,rgba(247,148,29,.24),transparent 32%)}.services .eyebrow{background:rgba(0,0,0,.04);color:#8a4b08}.services .section-head p{color:rgba(0,0,0,.58)}.service-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;position:relative}.service{min-height:300px;border-radius:28px;padding:26px;background:#101114;color:#fff;border:1px solid rgba(0,0,0,.06);box-shadow:0 20px 50px rgba(0,0,0,.12);display:flex;flex-direction:column;justify-content:space-between;transition:.28s}.service:hover{transform:translateY(-7px);background:linear-gradient(135deg,#111,#2a1704 70%);box-shadow:0 26px 58px rgba(0,0,0,.2)}.service-num{font-size:12px;color:var(--gold);font-weight:900;letter-spacing:2px}.service p{color:rgba(255,255,255,.62)}.tags{display:flex;flex-wrap:wrap;gap:7px;margin-top:18px}.tags span{font-size:10px;text-transform:uppercase;letter-spacing:.8px;border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.52);padding:6px 9px;border-radius:999px}

/* PROCESS */
.process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.step{position:relative;padding:28px;border:1px solid var(--line);border-radius:26px;background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.02))}.step:before{content:attr(data-step);display:block;width:50px;height:50px;border-radius:18px;background:rgba(247,148,29,.12);border:1px solid rgba(247,148,29,.25);display:grid;place-items:center;color:var(--gold);font-weight:900;margin-bottom:22px}.step:hover{border-color:var(--line2)}

/* WHY */
.why{background:var(--gold);color:#070707;position:relative;overflow:hidden}.why:before{content:"AAARON";position:absolute;right:-80px;top:14%;font-family:"Space Grotesk";font-size:190px;font-weight:900;color:rgba(0,0,0,.06);letter-spacing:-12px}.why-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:48px;align-items:center;position:relative}.why h2{color:#070707}.why p{color:rgba(0,0,0,.65);line-height:1.8}.why-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px}.why-card{padding:25px;border-radius:24px;background:rgba(0,0,0,.08);border:1px solid rgba(0,0,0,.09);transition:.25s}.why-card:hover{transform:translateY(-5px);background:rgba(0,0,0,.13)}.why-card p{font-size:14px}

/* EXPERTISE */
.expertise-grid{display:grid;grid-template-columns:.75fr 1.25fr;gap:38px}.sticky{position:sticky;top:100px;height:max-content}.expert-list{display:grid;gap:10px}.expert-item{border:1px solid var(--line);border-radius:22px;overflow:hidden;background:rgba(255,255,255,.035)}.expert-item summary{list-style:none;cursor:pointer;padding:21px 24px;display:flex;justify-content:space-between;gap:14px;align-items:center;font-family:"Space Grotesk";font-size:20px;font-weight:700}.expert-item summary::-webkit-details-marker{display:none}.expert-item summary span{color:var(--gold);font-size:13px;letter-spacing:1.5px}.expert-item p{padding:0 24px 24px;color:var(--muted);line-height:1.75}.expert-item[open]{border-color:var(--line2);background:rgba(247,148,29,.055)}

/* CONTACT */
.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:30px}.contact-card{border:1px solid var(--line);border-radius:var(--radius);padding:32px;background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.02));box-shadow:var(--shadow)}.contact-line{display:flex;gap:14px;padding:18px;border:1px solid var(--line);border-radius:20px;margin-top:12px;background:rgba(255,255,255,.035)}.contact-line b{display:block;color:var(--gold);font-size:11px;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}.contact-line span{color:#fff;font-weight:700}.form{display:grid;gap:12px}.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}.form input,.form select,.form textarea{width:100%;border:1px solid rgba(255,255,255,.12);border-radius:18px;background:rgba(255,255,255,.05);color:#fff;padding:16px;font:inherit;outline:0}.form textarea{min-height:130px;resize:vertical}.form input:focus,.form select:focus,.form textarea:focus{border-color:var(--line2);box-shadow:0 0 0 4px rgba(247,148,29,.08)}.form select option{background:#111}.full{width:100%;border:0;cursor:pointer}

/* FOOTER */
.footer{padding:50px 0 28px;border-top:1px solid rgba(247,148,29,.16);background:#070707}.footer-grid{display:grid;grid-template-columns:1.4fr repeat(3,1fr);gap:28px}.footer h4{font-family:"Space Grotesk";font-size:22px;margin-bottom:10px}.footer p,.footer a{color:var(--soft);font-size:14px;line-height:1.8}.footer a:hover{color:var(--gold)}.footer ul{list-style:none}.footer li{margin:8px 0}.copyright{margin-top:36px;padding-top:20px;border-top:1px solid var(--line);display:flex;justify-content:space-between;color:var(--soft);font-size:12px}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease, transform .7s ease}.reveal.show{opacity:1;transform:none}
@media(max-width:1020px){.hero-grid,.about-grid,.why-grid,.expertise-grid,.contact-grid{grid-template-columns:1fr}.service-grid{grid-template-columns:repeat(2,1fr)}.process-grid{grid-template-columns:repeat(2,1fr)}.hero-card{min-height:430px}.sticky{position:static}.section-head{align-items:start;flex-direction:column}.nav-links{display:none}.menu-btn{display:block}}
@media(max-width:640px){.container{width:min(100% - 28px,var(--max))}.nav{width:calc(100% - 20px);top:8px;border-radius:20px;padding-left:14px}.brand-badge{width:38px;height:38px}.brand-text strong{font-size:17px}.brand-text small{display:none}.hero{padding-top:120px}.hero p{font-size:15px}.hero-actions .btn{width:100%}.hero-card{min-height:360px;padding:18px;border-radius:26px}.seal{width:112px;height:112px;top:20px;left:20px}.seal span{font-size:15px}.floating-panel{left:16px;right:16px;bottom:16px;padding:15px}.mini-grid{grid-template-columns:1fr}.mini-stat{padding:12px}.mini-stat strong{font-size:23px}.section{padding:78px 0}.feature-grid,.service-grid,.process-grid,.why-cards,.form-row,.footer-grid{grid-template-columns:1fr}.about-copy,.contact-card{padding:24px;border-radius:24px}.copyright{flex-direction:column;gap:8px}.big-mark{font-size:76px}.marquee span{padding:15px 18px}}
</style>
</head>
